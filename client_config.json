{
  "application": {
    "name": "Cloud Honeypot Client",
    "version": "4.9.1",
    "author": "YesNext Technology"
  },
  "language": {
    "selected": "tr",
    "selected_by_user": false,
    "available_languages": [
      "tr",
      "en"
    ],
    "default": "en"
  },
  "ui": {
    "window_width": 1100,
    "window_height": 720,
    "theme": "dark",
    "show_loading_screen": true,
    "loading_timeout": 30,
    "dashboard_refresh_seconds": 10
  },
  "admin": {
    "require_admin_privileges": true,
    "auto_restart_as_admin": false,
    "show_admin_dialog": true
  },
  "logging": {
    "level": "INFO",
    "max_file_size_mb": 10,
    "backup_count": 5,
    "debug_mode": false
  },
  "api": {
    "base_url": "https://honeypot.yesnext.com.tr/api",
    "timeout": 30,
    "retry_count": 3,
    "tls_verify": true,
    "ca_bundle": "",
    "legacy_token_query": false
  },
  "services": {
    "auto_start": false,
    "rdp_port": 53389,
    "honeypots": [
      {
        "port": 3389,
        "service": "RDP",
        "enabled": true
      },
      {
        "port": 22,
        "service": "SSH",
        "enabled": true
      },
      {
        "port": 21,
        "service": "FTP",
        "enabled": false
      },
      {
        "port": 3306,
        "service": "MySQL",
        "enabled": false
      },
      {
        "port": 1433,
        "service": "MSSQL",
        "enabled": false
      },
      {
        "port": 80,
        "service": "HTTP",
        "enabled": false
      },
      {
        "port": 445,
        "service": "SMB",
        "enabled": false
      }
    ],
    "bind_address": "0.0.0.0"
  },
  "updates": {
    "auto_check": true,
    "check_interval_hours": 0.25,
    "show_notifications": true,
    "check_interval_minutes": 15,
    "startup_check_delay_seconds": 90,
    "verify_checksum": true
  },
  "advanced": {
    "startup_delay": 0,
    "minimize_to_tray": true,
    "auto_start_with_windows": false,
    "single_instance": true,
    "gui_health_monitoring": true,
    "gui_refresh_interval": 10,
    "prevent_gui_freeze": true,
    "windows_server_mode": true,
    "lazy_security_intel": true
  },
  "debug": {
    "enabled": false,
    "verbose_logging": false,
    "skip_admin_elevation": false,
    "test_mode": false,
    "skip_consent_dialog": false
  },
  "security": {
    "command_signing": true
  },
  "gui_lock": {
    "enabled": true
  },
  "logon_challenge": {
    "enabled": false,
    "auto_logoff": true
  },
  "self_protection": {
    "enabled": true
  },
  "notifications": {
    "webhook_url": "",
    "webhook_enabled": false
  },
  "performance_optimizer": {
    "enabled": true
  },
  "false_positive_tuner": {
    "enabled": true,
    "cleanup_interval_seconds": 3600
  },
  "cleanup": {
    "max_firewall_rules": 500,
    "max_ip_pool": 8000,
    "auto_enforce": true,
    "auto_enforce_interval_seconds": 3600
  },
  "threat_detection": {
    "command_poll_interval": 1,
    "health_report_interval": 60,
    "event_batch_interval": 120,
    "config_sync_interval": 300,
    "event_buffer_max_size": 500,
    "canary_check_interval": 30,
    "canary_file_paths": [
      "C:\\Users\\Public\\Documents\\.FinancialReport2024.xlsx.canary",
      "C:\\Users\\Public\\Desktop\\.ImportantNotes.docx.canary",
      "C:\\ProgramData\\.SystemConfig.dat.canary"
    ]
  }
}